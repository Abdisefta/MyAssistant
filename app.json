{
  "expo": {
    "name": "My Assistant",
    "slug": "MyAssistantFinal",
    "version": "1.7.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myassistantfinal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abdisefta.myassistantfinal"
    },
    "android": {
      "package": "com.abdisefta.myassistantfinal",
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-calendar",
        {
          "calendarPermission": "My Assistant behöver läsa din kalender för att visa möten.",
          "calendarWritePermission": "My Assistant behöver skriva i kalendern för att boka möten åt dig."
        }
      ],
      [
        "expo-apple-authentication"
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.374079725397-dms02mgthkod66afkr41bd41ok1q4chs"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "My Assistant behöver mikrofonen för att lyssna på dina frågor.",
          "speechRecognitionPermission": "My Assistant behöver röstigenkänning för att förstå vad du säger.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#8B7CF7",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "My Assistant använder din plats för att visa rätt väder där du befinner dig.",
          "locationWhenInUsePermission": "My Assistant använder din plats för att visa rätt väder där du befinner dig."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "My Assistant behöver tillgång till dina bilder för profilbilden på Hem."
        }
      ],
      "./plugins/with-android-cleartext.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "22e289d9-e041-4b20-a6c8-ec007b28d559"
      }
    }
  }
}
