# Kopiera till .env och fyll i värden. Committa aldrig .env med riktiga nycklar.
#
# EAS preview/production: alla EXPO_PUBLIC_* nedan måste sättas som EAS Environment
# Variables (Dashboard → Project → Environment variables, eller `eas env:create`).
# Preview-profilen i eas.json använder environment "preview"; production använder "production".
# Lokalt räcker .env; vid `eas build` utan .env på servern hämtas värden från EAS.

# Gemini AI (Google AI Studio — nyckel börjar med AIzaSy eller AQ.)
EXPO_PUBLIC_GEMINI_API_KEY=

# Firebase Authentication (console.firebase.google.com → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
# Android key (Google Cloud → Credentials → Android key auto created by Firebase → Show key)
EXPO_PUBLIC_FIREBASE_ANDROID_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In: Web client ID (OAuth 2.0) från Google Cloud Console.
# Måste matcha Firebase Authentication → Sign-in method → Google.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Android OAuth client — installerad app / APK (paket com.abdisefta.myassistantfinal)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Android OAuth client — Expo Go via QR (paket host.exp.exponent, SHA-1 38:08:DE:F4:62:D5:71:68:77:31:0E:67:31:4F:37:14:01:3A:43:30)
EXPO_PUBLIC_GOOGLE_EXPO_ANDROID_CLIENT_ID=

# iOS OAuth client (valfritt — finns default i app.json)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Alma Piper TTS (självhostad server — HTTP lokalt eller https på VPS)
# Android emulator: http://10.0.2.2:3001
# Fysisk telefon (samma WiFi): http://DIN-DATOR-IP:3001
# VPS: https://tts.dindoman.se
# Production Alma TTS (HTTP). Dev: use your machine IP instead of localhost on a physical device.
EXPO_PUBLIC_ALMA_TTS_URL=http://195.201.128.118:3001

# Admin analytics (dashboard på VPS port 3002)
EXPO_PUBLIC_ANALYTICS_URL=http://195.201.128.118:3002
EXPO_PUBLIC_ANALYTICS_API_KEY=myassistant-analytics-key
