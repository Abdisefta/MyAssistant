# Kopiera till .env och fyll i värden. Committa aldrig .env med riktiga nycklar.
#
# EAS preview/production: alla EXPO_PUBLIC_* nedan måste sättas som EAS Environment
# Variables (Dashboard → Project → Environment variables, eller `eas env:create`).
# Preview-profilen i eas.json använder environment "preview"; production använder "production".
# Lokalt räcker .env; vid `eas build` utan .env på servern hämtas värden från EAS.

# Gemini AI (Google AI Studio, börjar med AIzaSy)
EXPO_PUBLIC_GEMINI_API_KEY=

# Firebase Authentication (console.firebase.google.com → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In: Web client ID (OAuth 2.0) från Google Cloud Console.
# Måste matcha Firebase Authentication → Sign-in method → Google.
# Krävs för Firebase-inloggning med Google och för Gmail OAuth i appen.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
